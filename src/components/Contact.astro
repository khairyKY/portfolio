---

<section class="tight" id="contact">
  <div class="container">
    <div class="section-header" data-reveal>
      <div class="label">Contact</div>
      <h2 class="display">
        Let's <em>build</em> something<span class="dot">.</span>
      </h2>
      <p class="lead">
        Available for freelance, collaboration, and full-time opportunities.
      </p>
    </div>
    <div class="contact-grid" data-reveal>
      <a href={`mailto:${email}`} class="contact-card primary">
        <span class="contact-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </span>
        <span class="contact-label">Send an Email</span>
        <span class="contact-addr">{email}</span>
      </a>
      {cards.map(c => (
        <a href={c.href} class="contact-card" target={c.target} rel={c.target === '_blank' ? 'noopener noreferrer' : ''}>
          <span class="contact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" set:html={c.icon}></svg>
          </span>
          <span class="contact-label">{c.label}</span>
          <span class="contact-addr">{c.href.startsWith('tel:') ? phone : c.href.startsWith('https://wa.me') ? phone : ''}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
    padding: 24px;
    border-radius: 18px;
    border: 1px solid var(--line);
    background: var(--bone);
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s;
    position: relative;
  }
  .contact-card:hover { transform: translateY(-2px); }
  .contact-card.primary {
    background: var(--coral);
    border-color: var(--coral);
    color: #fff;
    grid-column: 1 / -1;
  }
  .contact-card.primary:hover { background: #e25e4a; }
  .contact-icon {
    width: 38px; height: 38px;
    border-radius: 50%;
    border: 1px solid var(--line);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .contact-card:hover .contact-icon {
    border-color: var(--coral);
    box-shadow: 0 0 14px 2px rgba(237, 111, 92, 0.2), 0 0 30px 4px rgba(237, 111, 92, 0.08);
  }
  .contact-card.primary .contact-icon { border-color: rgba(255,255,255,0.3); }
  .contact-card.primary:hover .contact-icon { box-shadow: 0 0 14px 2px rgba(255,255,255,0.25), 0 0 30px 4px rgba(255,255,255,0.1); }
  .contact-label {
    font-family: var(--sans);
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }
  .contact-card.primary .contact-label { color: #fff; }
  .contact-addr {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    word-break: break-all;
  }
  .contact-card.primary .contact-addr { color: rgba(255,255,255,0.8); }
  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>
