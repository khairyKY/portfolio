---
const experiences = [
  {
    company: "Shaheen for Import & Export",
    role: "Full-Stack & DevOps Engineer (Contract)",
    date: "Aug 2022 - Present",
    location: "Tanta, Egypt",
    bullets: [
      "Architected production Laravel 12 e-commerce platform (100+ routes, bilingual AR/EN, Paymob gateway, Filament 4 admin) serving 519 products across 27 Egyptian governorates",

      "Led a 30-day rescue sprint — 206 commits, 40+ merged PRs, 29 production issues closed. Restored 38 failing tests to 100% green, deployed zero-touch CI/CD via GitHub Actions",
      "Architected multi-region shipping cost matrix with vendor-split logic and an intelligent tire-size cross-reference engine",
      "Patched 12 production-blocking vulnerabilities — session timeouts, data leaks, and inventory exploits eliminated",
      "Launched enterprise SEO with structured data, multi-language routing, auto-sitemaps, and built an automated lead-capture engine for unmet demand tracking"
    ]
  },
  {
    company: "Optima Professional Services",
    role: "Cybersecurity Intern",
    date: "2026 - Present",
    location: "Egypt",
    bullets: [
      "Currently interning in cybersecurity operations and practices"
    ]
  },
  {
    company: "GB Academy (Ghabour Auto)",
    role: "Mechanical Engineering Intern",
    date: "2025",
    location: "Egypt",
    bullets: [
      "Interned in suspension, braking, and steering systems engineering"
    ]
  },
  {
    company: "DEPI Round 5",
    role: "Cybersecurity Trainee",
    date: "Jul 2026 - Present",
    location: "Remote",
    bullets: []
  },
  {
    company: "PC Building Store",
    role: "Technical Assistant",
    date: "Jun 2019 - Aug 2022",
    location: "Tanta, Egypt",
    bullets: [
      "Assembled and configured 40+ custom PC builds for gaming, creative, and business clients",
      "Diagnosed complex hardware issues: thermal management, BIOS conflicts, driver compatibility",
      "Advised customers on cost-effective component upgrades, driving repeat business"
    ]
  }
];
---

<section class="tight" id="experience">
  <div class="container">
    <div class="section-header" data-reveal>
      <div class="label">Experience</div>
      <h2 class="display">
        Where I've <em>worked</em><span class="dot">.</span>
      </h2>
    </div>
    {experiences.map((exp, i) => (
      <div class="exp-block" data-reveal>
        <div class="exp-head">
          <span class="roman">{String.fromCharCode(0x2160 + i)}.</span>
          <div>
            <h3>{exp.company}</h3>
            <div class="meta">{exp.role} &middot; {exp.location}</div>
          </div>
          <span class="exp-date">{exp.date}</span>
        </div>
        <ul class="bullets">
          {exp.bullets.map(b => <li>{b}</li>)}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .exp-block {
    padding: 28px 0;
    border-bottom: 1px solid var(--line);
  }
  .exp-block:last-child { border-bottom: none; }
  .exp-head {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 14px;
    align-items: baseline;
    margin-bottom: 16px;
  }
  .exp-head .roman {
    font-size: 18px;
    line-height: 1;
  }
  .exp-head h3 {
    font-family: var(--sans);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .exp-head .meta {
    font-size: 11px;
    margin-top: 3px;
    color: var(--ink-soft);
  }
  .exp-date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-mute);
    white-space: nowrap;
  }
  .bullets {
    list-style: none;
    padding: 0;
    margin-left: 42px;
  }
  .bullets li {
    position: relative;
    padding-left: 16px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin-bottom: 6px;
  }
  .bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--coral);
    opacity: 0.6;
  }
  @media (max-width: 768px) {
    .exp-head { grid-template-columns: 28px 1fr; }
    .exp-date { grid-column: 1 / -1; text-align: right; }
    .bullets { margin-left: 0; }
  }
</style>
