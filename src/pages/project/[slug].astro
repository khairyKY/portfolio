---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(p => ({
    params: { slug: p.id },
    props: { project: p },
  }));
}

const { project } = Astro.props;
const { data, body } = project;
const tagColors: Record<string, string> = {
  'Backend': '#4ECDC4', 'AI/ML': '#00BFFF', 'Frontend': '#A78BFA',
  'Embedded': '#E9B94A', 'Infrastructure': '#34D399'
};
---

<Layout title={`${data.title} — Khairy Shaheen`} description={data.description}>
  <article class="project-detail">
    <div class="container">
      <div class="detail-header" data-reveal>
        <a href="/#projects" class="back-link">&larr; Back to projects</a>
        <div class="detail-tags">
          {data.tags.map(t => (
            <span class="tag-pill" style={`border-color: ${tagColors[t] || 'var(--line)'}; color: ${tagColors[t] || 'var(--ink-soft)'}`}>{t}</span>
          ))}
        </div>
        <h1 class="display">{data.title}<span class="dot">.</span></h1>
        <p class="lead">{data.description}</p>
      </div>

      <div class="detail-layout">
        <div class="detail-main">
          {data.image && (
            <div class="detail-img-card" data-reveal>
              <img src={data.image} alt={data.title} loading="lazy" />
            </div>
          )}

          <div class="detail-body" data-reveal>
            {body.split('\n\n').map(p => (
              <p>{p.trim()}</p>
            ))}
          </div>
        </div>

        <aside class="detail-sidebar" data-reveal>
          <div class="sidebar-card">
            <div class="meta-item">
              <span class="meta-label">Date</span>
              <span class="meta-value">{data.date}</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Stack</span>
              <div class="meta-pills">
                {data.tech.map(t => <span class="tech-pill">{t}</span>)}
              </div>
            </div>
            {data.github && (
              <div class="meta-item">
                <span class="meta-label">Code</span>
                <a href={data.github} class="btn-ghost-sm" target="_blank" rel="noopener noreferrer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                  View Repo
                </a>
              </div>
            )}
            {data.demo && (
              <div class="meta-item">
                <span class="meta-label">Demo</span>
                <a href={data.demo} class="inline-link" target="_blank">{data.demo.replace('https://', '')}</a>
              </div>
            )}
          </div>
        </aside>
      </div>
    </div>
  </article>
</Layout>

<style>
  .project-detail { padding: 80px 0 120px; }
  .detail-header { margin-bottom: 40px; }
  .back-link {
    display: inline-block;
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-mute);
    text-decoration: none;
    margin-bottom: 20px;
    transition: color 0.18s;
  }
  .back-link:hover { color: var(--coral); }
  .detail-tags {
    display: flex;
    gap: 8px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .tag-pill {
    padding: 4px 12px;
    border-radius: 999px;
    border: 1px solid;
    font-family: var(--sans);
    font-size: 11px;
    font-weight: 600;
  }
  .detail-header h1 { margin-bottom: 16px; }

  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 40px;
    align-items: start;
  }
  .detail-img-card {
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 32px;
    box-shadow: var(--shadow);
    border: 1px solid var(--line-soft);
  }
  .detail-img-card img {
    width: 100%;
    height: auto;
    display: block;
  }
  .detail-body {
    font-family: var(--body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-soft);
  }
  .detail-body p { margin-bottom: 18px; }

  .sidebar-card {
    background: var(--bone);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    position: sticky;
    top: 100px;
  }
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .meta-label {
    font-family: var(--sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .meta-value {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--ink);
  }
  .meta-pills { display: flex; flex-wrap: wrap; gap: 5px; }
  .btn-ghost-sm {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--line);
    font-family: var(--sans);
    font-size: 12px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    transition: all 0.18s ease;
    white-space: nowrap;
    width: fit-content;
  }
  .btn-ghost-sm:hover {
    background: var(--line-soft);
    border-color: var(--coral);
    color: var(--coral);
  }
  .btn-ghost-sm svg { width: 14px; height: 14px; }
  .inline-link { color: var(--coral); text-decoration: none; }
  .inline-link:hover { text-decoration: underline; }

  @media (max-width: 860px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
    .sidebar-card {
      position: static;
    }
  }
</style>
